---
import '../styles/global.css';
import {
  APP_NAME,
  APP_STORE_ID,
  APP_STORE_URL,
  LEGAL_NAME,
  SITE_LANGUAGES,
  SITE_URL,
} from '../config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonical?: string;
}

const {
  title = 'AstrologyX: Birth Chart & Daily Horoscope App for iPhone',
  description =
    'AstrologyX is a precision astrology app for iPhone. Get your personalized birth chart, daily horoscope, planetary transits, and synastry compatibility — powered by NASA star-position data.',
  ogImage = '/og-image.png',
  ogImageAlt = 'AstrologyX — Birth Chart & Daily Horoscope App for iPhone',
  canonical,
} = Astro.props;

const resolvedCanonical = canonical ?? SITE_URL + Astro.url.pathname;
const buildIso = new Date().toISOString();

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  name: APP_NAME,
  url: SITE_URL,
  inLanguage: 'en',
  publisher: { '@id': `${SITE_URL}/#organization` },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: APP_NAME,
  legalName: LEGAL_NAME,
  url: SITE_URL,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE_URL}/img/logo.png`,
    width: 512,
    height: 512,
  },
  sameAs: [APP_STORE_URL],
};
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#131313" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- hreflang: site is currently English-only; declare self-reference + x-default -->
    {SITE_LANGUAGES.map((lang) => (
      <link rel="alternate" hreflang={lang} href={resolvedCanonical} />
    ))}
    <link rel="alternate" hreflang="x-default" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={resolvedCanonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"            content={SITE_URL + ogImage} />
    <meta property="og:image:secure_url" content={SITE_URL + ogImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type"   content="image/png" />
    <meta property="og:image:alt"    content={ogImageAlt} />
    <meta property="og:locale"       content="en_US" />
    <meta property="og:site_name"    content={APP_NAME} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={SITE_URL + ogImage} />
    <meta name="twitter:image:alt"   content={ogImageAlt} />

    <!-- iOS Safari: native Smart App Banner (top). QR in hero/CTA is lg+ only. -->
    <meta
      name="apple-itunes-app"
      content={`app-id=${APP_STORE_ID}, app-argument=${encodeURIComponent(resolvedCanonical)}`}
    />

    <!-- iOS web-app share metadata (used when added to Home Screen / shared into Messages) -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={APP_NAME} />
    <meta name="format-detection" content="telephone=no" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Structured data: WebSite + Organization (all pages) -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="scroll-progress-line hidden lg:block" aria-hidden="true">
      <div class="scroll-progress-line__track"></div>
      <div class="scroll-progress-line__fill"></div>
    </div>
    <slot />
  </body>
</html>
