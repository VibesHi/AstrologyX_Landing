---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Overview from '../components/sections/Overview.astro';
import Benefits from '../components/sections/Benefits.astro';
import AppShowcase from '../components/sections/AppShowcase.astro';
import FeatureDive from '../components/sections/FeatureDive.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import FAQ from '../components/sections/FAQ.astro';
import { FAQ_ITEMS } from '../data/faq';
import {
  APP_LANGUAGES,
  APP_NAME,
  APP_STORE_ID,
  APP_STORE_URL,
  APP_VERSION,
  LEGAL_NAME,
  SITE_URL,
} from '../config';

const buildIso = new Date().toISOString();

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': ['SoftwareApplication', 'MobileApplication'],
  '@id': `${SITE_URL}/#software`,
  name: APP_NAME,
  alternateName: 'AstrologyX: Birth Chart & Horoscope',
  operatingSystem: 'iOS 16+',
  applicationCategory: 'LifestyleApplication',
  applicationSubCategory: 'Astrology',
  url: SITE_URL,
  downloadUrl: APP_STORE_URL,
  installUrl: APP_STORE_URL,
  softwareVersion: APP_VERSION,
  inLanguage: [...APP_LANGUAGES],
  dateModified: buildIso,
  identifier: `apple-app-id:${APP_STORE_ID}`,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
  },
  featureList: [
    'Personalized daily horoscopes',
    'Birth chart (natal chart) readings',
    'Real-time planetary transit tracking',
    'Synastry compatibility analysis',
    'NASA-powered ephemeris data',
  ],
  description:
    'AstrologyX is a precision astrology app for iPhone. Get your personalized birth chart, daily horoscope, planetary transits, and synastry compatibility — powered by NASA star-position data.',
  screenshot: [
    `${SITE_URL}/birthChartImage.png`,
    `${SITE_URL}/planetaryMotionImage.png`,
    `${SITE_URL}/insightsImage.png`,
  ],
  image: `${SITE_URL}/og-image.png`,
  creator: {
    '@type': 'Organization',
    name: LEGAL_NAME,
    legalName: LEGAL_NAME,
  },
  publisher: { '@id': `${SITE_URL}/#organization` },
  // TODO: re-enable once rating value is confirmed (see PR notes)
  // aggregateRating: {
  //   '@type': 'AggregateRating',
  //   ratingValue: '3.55',
  //   ratingCount: 9,
  //   bestRating: 5,
  //   worstRating: 1,
  // },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL + '/',
    },
  ],
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${SITE_URL}/#webpage`,
  url: SITE_URL + '/',
  name: 'AstrologyX: Birth Chart & Daily Horoscope App for iPhone',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  primaryImageOfPage: { '@type': 'ImageObject', url: `${SITE_URL}/og-image.png` },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#overview p', '#faq dt'],
  },
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to read your birth chart in AstrologyX',
  description:
    'Step-by-step guide to opening and interpreting your birth chart in the AstrologyX iPhone app.',
  totalTime: 'PT5M',
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'USD', value: '0' },
  supply: [{ '@type': 'HowToSupply', name: 'iPhone running iOS 16 or later' }],
  tool: [{ '@type': 'HowToTool', name: 'AstrologyX app' }],
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Install AstrologyX',
      text: 'Download AstrologyX from the App Store and open it on your iPhone.',
      url: APP_STORE_URL,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Enter your birth details',
      text: 'Enter your full birth date, exact birth time, and birth location. AstrologyX uses these to calculate your personalized birth chart.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Open your birth chart',
      text: 'Open the Birth Chart tab to view your natal chart wheel — showing your sun, moon, rising sign, and planetary placements across the twelve houses.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Tap any planet, sign, or house',
      text: 'Tap any planet, sign, or house in the chart to see a clear, beginner-friendly interpretation of what it means for your personality and life themes.',
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'Follow daily transits',
      text: 'Use the daily horoscope and transit feed to see how current planetary movements interact with your specific birth chart positions.',
    },
  ],
};
---
<BaseLayout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  </Fragment>
  <Nav />
  <main id="main-content" class="min-w-0">
    <Hero />
    <Overview />
    <Benefits />
    <AppShowcase />
    <FeatureDive />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
