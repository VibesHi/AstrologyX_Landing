---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

const rawHtml = readFileSync(resolve('privacyPolicy.html'), 'utf-8');
---
<BaseLayout
  title="Privacy Policy — AstrologyX"
  description="AstrologyX privacy policy — how we collect, use, and protect your data."
>
  <div class="min-h-screen bg-white">
    <!-- Simple top bar instead of transparent nav for legal pages -->
    <header class="border-b border-gray-200 h-16 flex items-center px-6">
      <div class="max-w-3xl mx-auto w-full flex items-center justify-between">
        <a href="/" class="font-black text-black text-sm tracking-tight">AstrologyX</a>
        <a href="/" class="text-xs text-gray-500 hover:text-black transition-colors">← Back to home</a>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-20">
      <div
        class="prose prose-sm max-w-none
          [&_h1]:font-black [&_h1]:text-3xl [&_h1]:tracking-tight [&_h1]:mb-2
          [&_h2]:font-bold [&_h2]:text-xl [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:tracking-tight
          [&_h3]:font-semibold [&_h3]:text-base [&_h3]:mt-6 [&_h3]:mb-2
          [&_p]:text-gray-600 [&_p]:leading-relaxed [&_p]:mb-4
          [&_a]:text-black [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-gray-600
          [&_ul]:list-none [&_ul]:pl-0
          [&_li]:border-l-2 [&_li]:border-gray-100 [&_li]:pl-4 [&_li]:mb-4
          [&_strong]:text-black [&_strong]:font-semibold"
        set:html={rawHtml}
      />
    </main>

    <Footer />
  </div>
</BaseLayout>
