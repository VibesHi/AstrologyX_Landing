---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

const rawHtml = readFileSync(resolve('privacyPolicy.html'), 'utf-8');
---
<BaseLayout
  title="Privacy Policy — AstrologyX"
  description="AstrologyX privacy policy — how we collect, use, and protect your data."
>
  <div class="min-h-screen bg-white text-gray-900 font-sans antialiased">
    <!-- Top bar: same horizontal padding + logo size as main site Nav -->
    <header
      class="flex w-full min-w-0 items-center border-b border-gray-200 bg-white pl-[max(1.25rem,env(safe-area-inset-left,0px))] pr-[max(1.25rem,env(safe-area-inset-right,0px))] lg:pl-[max(3rem,env(safe-area-inset-left,0px))] lg:pr-[max(3rem,env(safe-area-inset-right,0px))] py-5 sm:py-6"
    >
      <a
        href="/"
        class="min-w-0 shrink text-base font-black tracking-tighter text-black uppercase select-none sm:text-xl"
      >
        AstrologyX
      </a>
    </header>

    <main
      class="pl-[max(1.25rem,env(safe-area-inset-left,0px))] pr-[max(1.25rem,env(safe-area-inset-right,0px))] lg:pl-[max(3rem,env(safe-area-inset-left,0px))] lg:pr-[max(3rem,env(safe-area-inset-right,0px))] py-20 font-sans"
    >
      <div class="max-w-3xl">
      <div
        class="max-w-none text-left font-sans text-[0.9375rem] leading-relaxed sm:text-base
          [&_h1]:font-sans [&_h2]:font-sans [&_h3]:font-sans [&_h4]:font-sans [&_p]:font-sans [&_li]:font-sans [&_a]:font-sans [&_strong]:font-sans
          [&_h1]:font-black [&_h1]:text-3xl [&_h1]:text-gray-950 [&_h1]:tracking-tight [&_h1]:mb-2
          [&_h2]:font-bold [&_h2]:text-xl [&_h2]:text-gray-950 [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:tracking-tight
          [&_h3]:font-semibold [&_h3]:text-base [&_h3]:text-gray-950 [&_h3]:mt-6 [&_h3]:mb-2
          [&_h4]:font-semibold [&_h4]:text-gray-950 [&_h4]:mt-4 [&_h4]:mb-2
          [&_p]:text-gray-800 [&_p]:leading-relaxed [&_p]:mb-4
          [&_li]:text-gray-800 [&_li]:mb-4 [&_li]:border-l-2 [&_li]:border-gray-200 [&_li]:pl-4
          [&_a]:font-medium [&_a]:text-gray-900 [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-black
          [&_ul]:list-none [&_ul]:pl-0
          [&_strong]:text-gray-950 [&_strong]:font-semibold"
        set:html={rawHtml}
      />
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
