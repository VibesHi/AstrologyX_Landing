---
import { APP_STORE_URL } from '../../config';
---
<section
  id="app-showcase"
  class="py-24 md:py-32 bg-white overflow-hidden"
  aria-label="App showcase"
>
  <div class="text-center mb-16 md:mb-24 px-6 max-w-5xl mx-auto">
    <h2 class="text-black text-4xl md:text-6xl font-black uppercase tracking-tighter mb-4">
      The interface of destiny
    </h2>
    <p class="text-neutral-500 text-sm md:text-base uppercase tracking-[0.2em] font-mono">
      Precision layout. Editorial calm.
    </p>
  </div>

  <div class="relative w-full max-w-6xl mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 items-center gap-16 md:gap-24">
    <!-- Phone mock (CSS) -->
    <div class="order-2 md:order-1 flex justify-center">
      <div
        class="bg-black p-8 md:p-12 aspect-[9/19] max-w-[min(100%,320px)] w-full border-[12px] border-[#222] shadow-2xl overflow-hidden"
        style="border-radius: 3rem;"
      >
        <div class="h-full w-full bg-[#0E0E0E] flex flex-col p-4 md:p-6 gap-6 min-h-[420px]">
          <div class="flex justify-between items-center text-white/50 text-xs font-mono">
            <span>9:41</span>
            <div class="flex gap-1.5 items-center" aria-hidden="true">
              <span class="w-3 h-2 border border-white/40 rounded-sm inline-block" />
              <span class="w-3 h-2 border border-white/40 rounded-sm inline-block" />
            </div>
          </div>
          <div class="mt-4">
            <p class="text-white/40 text-[10px] uppercase font-mono tracking-widest mb-2">Current transit</p>
            <h4 class="text-white text-2xl md:text-3xl font-bold leading-none uppercase">
              Saturn<br />retrograde
            </h4>
          </div>
          <div class="flex-grow flex items-center justify-center min-h-[140px]">
            <div class="w-full max-w-[200px] aspect-square border border-white/10 rounded-full relative flex items-center justify-center">
              <div class="absolute w-full h-px bg-white/20 rotate-45"></div>
              <div class="absolute w-full h-px bg-white/20 -rotate-45"></div>
              <div class="w-3/4 aspect-square border border-white/5 rounded-full flex items-center justify-center">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" class="text-white" aria-hidden="true">
                  <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" fill="currentColor" opacity="0.9"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="bg-white/5 p-4 border-l-2 border-white mt-auto">
            <p class="text-white text-xs leading-relaxed italic">
              A useful time to review structure before you expand. Keep plans realistic.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Modules -->
    <div class="order-1 md:order-2 flex flex-col gap-12 text-left">
      <div class="space-y-4 reveal" id="showcase-m1">
        <span class="text-black font-mono text-xs px-2 py-1 border border-black/20 inline-block">Module 01</span>
        <h3 class="text-3xl md:text-4xl font-black text-black uppercase tracking-tight">
          Ultra-minimal charting
        </h3>
        <p class="text-neutral-600 leading-relaxed">
          No clutter — your chart and readings stay readable. Data-forward layout so you can scan placements and context quickly.
        </p>
      </div>
      <div class="space-y-4 reveal" id="showcase-m2">
        <span class="text-black font-mono text-xs px-2 py-1 border border-black/20 inline-block">Module 02</span>
        <h3 class="text-3xl md:text-4xl font-black text-black uppercase tracking-tight">
          Daily synthesis
        </h3>
        <p class="text-neutral-600 leading-relaxed">
          Daily guidance connects aspects and transits into plain language — tuned to your chart, not generic sign blurbs.
        </p>
      </div>
      <div>
        <a
          href={APP_STORE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="badge-appstore inline-block"
          aria-label="Download AstrologyX on the App Store"
        >
          <img
            src="/img/appstore.png"
            alt="Download on the App Store"
            width="140"
            height="47"
            loading="lazy"
            class="h-12 w-auto"
          />
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  ['showcase-m1', 'showcase-m2'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
