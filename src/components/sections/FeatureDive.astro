---
import { Image } from 'astro:assets';
import { APP_STORE_URL } from '../../config';
import imgBirth from '../../assets/features/feature-birth.png';
import imgHoroscope from '../../assets/features/feature-horoscope.png';
import imgSynastry from '../../assets/features/feature-synastry.png';

const blocks = [
  {
    headline: 'Personalized birth chart',
    body: 'Your chart is built from the time and place you were born — houses, aspects, and placements in one clear view you can return to anytime.',
    image: imgBirth,
    alt: 'Abstract minimalist chart lines on dark background',
    imageSide: 'right' as const,
    cta: 'Get the app',
  },
  {
    headline: 'Horoscope intelligence',
    body: 'Daily guidance reflects what is active in your chart — not recycled copy written for every sign. Short, specific, and easy to act on.',
    image: imgHoroscope,
    alt: 'Abstract orbital visualization on dark background',
    imageSide: 'left' as const,
    cta: 'View on App Store',
  },
  {
    headline: 'Social synastry',
    body: 'Compare charts to see compatibility and tension points with clarity — useful context for relationships you care about.',
    image: imgSynastry,
    alt: 'Abstract network pattern on dark background',
    imageSide: 'right' as const,
    cta: 'Compare charts',
  },
];
---
<div id="features" aria-label="Feature details">
  {blocks.map(({ headline, body, image, alt, imageSide, cta }, i) => (
    <div
      class:list={[
        'grid grid-cols-1 md:grid-cols-2 border-b border-white/10',
        i === blocks.length - 1 && 'border-b-0',
      ]}
    >
      {imageSide === 'right' ? (
        <>
          <div
            class="p-10 md:p-20 flex flex-col justify-center items-start md:border-r border-white/10"
            style="background: #131313;"
          >
            <h2 class="text-4xl md:text-6xl font-black uppercase text-white mb-8 leading-[0.95] tracking-tight">
              {headline}
            </h2>
            <p class="text-[#c6c6c6] text-lg md:text-xl leading-relaxed mb-12 max-w-xl">{body}</p>
            <a
              href={APP_STORE_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="border border-white text-white px-8 py-4 uppercase font-bold text-sm tracking-widest hover:bg-white hover:text-black transition-colors"
            >
              {cta}
            </a>
          </div>
          <div
            class="min-h-[280px] md:min-h-[400px] flex items-center justify-center p-8 md:p-12 overflow-hidden"
            style="background: #0e0e0e;"
          >
            <Image
              src={image}
              alt={alt}
              width={800}
              height={600}
              loading="lazy"
              class="w-full h-full max-h-[min(420px,50vh)] object-cover grayscale opacity-60"
            />
          </div>
        </>
      ) : (
        <>
          <div
            class="min-h-[280px] md:min-h-[400px] flex items-center justify-center p-8 md:p-12 overflow-hidden"
            style="background: #0e0e0e;"
          >
            <Image
              src={image}
              alt={alt}
              width={800}
              height={600}
              loading="lazy"
              class="w-full h-full max-h-[min(420px,50vh)] object-cover grayscale opacity-60"
            />
          </div>
          <div
            class="p-10 md:p-20 flex flex-col justify-center items-start md:border-l border-white/10"
            style="background: #131313;"
          >
            <h2 class="text-4xl md:text-6xl font-black uppercase text-white mb-8 leading-[0.95] tracking-tight">
              {headline}
            </h2>
            <p class="text-[#c6c6c6] text-lg md:text-xl leading-relaxed mb-12 max-w-xl">{body}</p>
            <a
              href={APP_STORE_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="border border-white text-white px-8 py-4 uppercase font-bold text-sm tracking-widest hover:bg-white hover:text-black transition-colors"
            >
              {cta}
            </a>
          </div>
        </>
      )}
    </div>
  ))}
</div>
