---
import { Image } from 'astro:assets';
import { APP_STORE_URL } from '../../config';
import imgBirth from '../../assets/features/feature-birth.png';
import imgHoroscope from '../../assets/features/feature-horoscope.png';

type Block = {
  headline?: string;
  headlineLines?: readonly [string, string];
  paragraphs: readonly string[];
  image?: typeof imgBirth;
  /** Served from /public, e.g. /insightsImage.png */
  publicImage?: { src: string; width: number; height: number };
  alt: string;
  imageSide: 'left' | 'right';
  cta: string;
  imageClass?: string;
};

const blocks: Block[] = [
  {
    headlineLines: ['Understand', 'BIRTH CHART'] as const,
    paragraphs: [
      'Your Birth Chart is the foundation of real astrology — a unique map of the sky at the moment you were born. It explains your personality, emotional patterns, strengths, challenges, and the structure of who you are.',
    ],
    image: imgBirth,
    alt: 'Abstract minimalist chart lines on dark background',
    imageSide: 'right',
    cta: 'Get ur chart',
    imageClass: 'opacity-50',
  },
  {
    headline: 'decode planetary motion',
    paragraphs: [
      "Powered by NASA's star-position data and our own proprietary tech, we create transit horoscopes with exceptional accuracy—made just for you.",
    ],
    image: imgHoroscope,
    alt: 'Abstract orbital visualization on dark background',
    imageSide: 'left',
    cta: 'try it now',
  },
  {
    headline: 'real-time insights',
    paragraphs: [
      'Your 2026 astro readings have officially arrived in the app, complete with fresh insights, predictions, and personalized guidance for the year ahead.',
    ],
    publicImage: { src: '/insightsImage.png', width: 1200, height: 1200 },
    alt: 'Network of insight nodes',
    imageSide: 'right',
    cta: 'See insights',
    imageClass: 'opacity-95 grayscale-0',
  },
];
---
<div id="features" aria-label="Feature details">
  {blocks.map(({ headline, headlineLines, paragraphs, image, publicImage, alt, imageSide, cta, imageClass }, i) => (
    <section
      id={i === 0 ? 'birth-chart' : undefined}
      class:list={[
        'grid grid-cols-1 lg:grid-cols-2 border-b border-white/[0.04]',
        i === blocks.length - 1 && 'border-b-0',
      ]}
    >
      {imageSide === 'right' ? (
        <>
          <div
            class="order-2 lg:order-1 min-w-0 p-10 lg:p-24 flex flex-col justify-center items-start lg:border-r border-white/[0.04] min-h-[280px] lg:min-h-[640px]"
            style="background: #131313;"
          >
            <h2 class="text-2xl sm:text-4xl lg:text-6xl font-black uppercase text-white mb-8 leading-[0.95] tracking-tight text-balance break-words">
              {headlineLines ? (
                <>
                  <span class="block whitespace-pre-wrap">{headlineLines[0]}</span>
                  <span class="block whitespace-pre-wrap">{headlineLines[1]}</span>
                </>
              ) : (
                headline
              )}
            </h2>
            <div class="text-[#c6c6c6] text-lg lg:text-xl leading-relaxed mb-12 max-w-xl space-y-0">
              {paragraphs.map((p) => (
                <p class="mb-0 last:mb-0 leading-[1.625]">{p}</p>
              ))}
            </div>
            <a
              href={APP_STORE_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="border border-white text-white px-8 py-4 uppercase font-bold text-sm tracking-widest hover:bg-white hover:text-black transition-colors"
            >
              {cta}
            </a>
          </div>
          <div
            class:list={[
              'order-1 lg:order-2 min-w-0 min-h-[280px] lg:min-h-[640px] flex items-center justify-center overflow-hidden',
              publicImage ? 'p-6' : 'p-8 lg:p-12',
            ]}
            style="background: #0e0e0e;"
          >
            {publicImage ? (
              <div
                class="relative mx-auto w-full max-w-[min(100%,min(90vw,28rem))] aspect-square min-h-0 rounded-sm bg-[#121212] ring-1 ring-white/[0.06]"
              >
                <div class="absolute inset-6 flex min-h-0 items-center justify-center">
                  <img
                    src={publicImage.src}
                    alt={alt}
                    width={publicImage.width}
                    height={publicImage.height}
                    loading="lazy"
                    decoding="async"
                    class:list={['h-full w-full object-contain', imageClass ?? '']}
                  />
                </div>
              </div>
            ) : (
              <Image
                src={image!}
                alt={alt}
                width={800}
                height={600}
                loading="lazy"
                class:list={[
                  'w-full h-full max-h-[min(420px,50vh)] object-cover grayscale',
                  imageClass ?? 'opacity-60',
                ]}
              />
            )}
          </div>
        </>
      ) : (
        <>
          <div
            class:list={[
              'order-1 min-w-0 min-h-[280px] lg:min-h-[640px] flex items-center justify-center overflow-hidden',
              publicImage ? 'p-6' : 'p-8 lg:p-12',
            ]}
            style="background: #0e0e0e;"
          >
            {publicImage ? (
              <div
                class="relative mx-auto w-full max-w-[min(100%,min(90vw,28rem))] aspect-square min-h-0 rounded-sm bg-[#121212] ring-1 ring-white/[0.06]"
              >
                <div class="absolute inset-6 flex min-h-0 items-center justify-center">
                  <img
                    src={publicImage.src}
                    alt={alt}
                    width={publicImage.width}
                    height={publicImage.height}
                    loading="lazy"
                    decoding="async"
                    class:list={['h-full w-full object-contain', imageClass ?? '']}
                  />
                </div>
              </div>
            ) : (
              <Image
                src={image!}
                alt={alt}
                width={800}
                height={600}
                loading="lazy"
                class:list={[
                  'w-full h-full max-h-[min(420px,50vh)] object-cover grayscale',
                  imageClass ?? 'opacity-60',
                ]}
              />
            )}
          </div>
          <div
            class="order-2 min-w-0 p-10 lg:p-24 flex flex-col justify-center items-start lg:border-l border-white/[0.04] min-h-[280px] lg:min-h-[640px]"
            style="background: #131313;"
          >
            <h2 class="text-2xl sm:text-4xl lg:text-6xl font-black uppercase text-white mb-8 leading-[0.95] tracking-tight text-balance break-words">
              {headlineLines ? (
                <>
                  <span class="block whitespace-pre-wrap">{headlineLines[0]}</span>
                  <span class="block whitespace-pre-wrap">{headlineLines[1]}</span>
                </>
              ) : (
                headline
              )}
            </h2>
            <div class="text-[#c6c6c6] text-lg lg:text-xl leading-relaxed mb-12 max-w-xl space-y-0">
              {paragraphs.map((p) => (
                <p class="mb-0 last:mb-0 leading-[1.625]">{p}</p>
              ))}
            </div>
            <a
              href={APP_STORE_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="border border-white text-white px-8 py-4 uppercase font-bold text-sm tracking-widest hover:bg-white hover:text-black transition-colors"
            >
              {cta}
            </a>
          </div>
        </>
      )}
    </section>
  ))}
</div>
