---
const features = [
  {
    eyebrow: 'Precision',
    headline: 'NASA data.\nNo guesswork.',
    stat: '0.001°',
    statLabel: 'positional accuracy',
    body: "Every planetary position is calculated from JPL ephemeris data — the same orbital mechanics used by space agencies. Your Moon sign is accurate to the minute, not rounded to the nearest degree.",
    bg: '#ffffff',
    side: 'left',
  },
  {
    eyebrow: 'Connection',
    headline: 'Understand\nanyone.',
    stat: '144',
    statLabel: 'aspect combinations',
    body: 'Synastry analysis maps the planetary connections between two charts. House overlays reveal where someone enters your life story. Composite charts show what a relationship becomes as its own entity.',
    bg: '#F9F7F4',
    side: 'right',
  },
];
---
<div id="features" aria-label="Feature details">
  {features.map(({ eyebrow, headline, stat, statLabel, body, bg, side }, idx) => (
    <section
      id={`feature-${idx}`}
      class="section-pad reveal"
      style={`background: ${bg};`}
      aria-label={eyebrow}
    >
      <div class="max-w-5xl mx-auto px-6">
        <div
          class={`flex flex-col gap-12 items-center ${
            side === 'right' ? 'lg:flex-row-reverse' : 'lg:flex-row'
          }`}
        >
          <!-- Visual block -->
          <div class="flex-1 flex items-center justify-center">
            <div
              class="relative flex items-center justify-center"
              style="width: 100%; max-width: 380px; aspect-ratio: 1 / 1; border-radius: 28px; border: 1px solid #EBEBEB; background: #ffffff; overflow: hidden;"
            >
              <!-- Illustration -->
              <div class="flex items-center justify-center w-full h-full p-10">
                {idx === 0 && (
                  <svg width="160" height="160" viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="80" cy="80" r="74" stroke="#111" stroke-width="1"   opacity="0.12"/>
                    <circle cx="80" cy="80" r="56" stroke="#111" stroke-width="0.75" opacity="0.16"/>
                    <circle cx="80" cy="80" r="38" stroke="#111" stroke-width="0.75" opacity="0.2"/>
                    <circle cx="80" cy="80" r="18" stroke="#111" stroke-width="0.75" opacity="0.25"/>
                    <circle cx="80" cy="80" r="5"  fill="#111"   opacity="0.8"/>
                    <circle cx="80" cy="6"  r="4.5" fill="#111"  opacity="0.7"/>
                    <circle cx="154" cy="80" r="3.5" fill="#111" opacity="0.55"/>
                    <circle cx="80" cy="154" r="4"   fill="#111" opacity="0.6"/>
                    <circle cx="6"  cy="80"  r="3"   fill="#111" opacity="0.45"/>
                    <circle cx="24" cy="28"  r="3"   fill="#111" opacity="0.6"/>
                    <line x1="80" y1="6"   x2="154" y2="80"  stroke="#111" stroke-width="0.5" opacity="0.2"/>
                    <line x1="80" y1="6"   x2="6"   y2="80"  stroke="#111" stroke-width="0.5" opacity="0.15"/>
                    <line x1="154" y1="80" x2="80"  y2="154" stroke="#111" stroke-width="0.5" opacity="0.18"/>
                  </svg>
                )}
                {idx === 1 && (
                  <svg width="160" height="160" viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="58"  cy="80" r="44" stroke="#111" stroke-width="1"   opacity="0.16"/>
                    <circle cx="102" cy="80" r="44" stroke="#111" stroke-width="1"   opacity="0.16"/>
                    <!-- Vesica overlap fill -->
                    <path
                      d="M80 42 C66 54 66 106 80 118 C94 106 94 54 80 42Z"
                      fill="#111"
                      opacity="0.045"
                    />
                    <circle cx="14"  cy="80" r="5"   fill="#111" opacity="0.6"/>
                    <circle cx="146" cy="80" r="5"   fill="#111" opacity="0.6"/>
                    <circle cx="80"  cy="80" r="3.5" fill="#111" opacity="0.85"/>
                    <line x1="14" y1="80" x2="146" y2="80" stroke="#111" stroke-width="0.5" opacity="0.2"/>
                  </svg>
                )}
              </div>

              <!-- Stat — bottom right inside the card -->
              <div
                class="absolute bottom-5 right-6 text-right"
                aria-label={`${stat} ${statLabel}`}
              >
                <span
                  class="block font-black leading-none"
                  style="font-size: 1.75rem; color: #111111;"
                >
                  {stat}
                </span>
                <span
                  class="block"
                  style="font-size: 0.625rem; letter-spacing: 0.12em; text-transform: uppercase; color: #BEBEBE; margin-top: 3px;"
                >
                  {statLabel}
                </span>
              </div>
            </div>
          </div>

          <!-- Copy -->
          <div class="flex-1 max-w-md">
            <span class="pill-tag mb-5 inline-flex">{eyebrow}</span>
            <h3
              class="font-black leading-tight tracking-tight mb-5 mt-3 whitespace-pre-line"
              style="font-size: var(--text-headline); color: #111111;"
            >
              {headline}
            </h3>
            <div
              class="fade-line mb-6"
              style="height: 1px; background: #EBEBEB; width: 40px;"
              aria-hidden="true"
            ></div>
            <p style="font-size: var(--text-body-lg); color: #8A8A8A; line-height: 1.7;">
              {body}
            </p>
          </div>
        </div>
      </div>
    </section>
  ))}
</div>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('[id^="feature-"]').forEach((el) => observer.observe(el));
</script>
