---
import { APP_STORE_URL } from '../../config';
---
<section
  id="download"
  class="section-pad"
  style="background: #F9F7F4;"
  aria-label="Download call to action"
>
  <div class="max-w-2xl mx-auto px-6 text-center reveal" id="cta-block">

    <span class="pill-tag mb-8 inline-flex">Free download</span>

    <h2
      class="font-black leading-[0.95] tracking-tighter mt-4 mb-6"
      style="font-size: var(--text-hero); color: #111111;"
    >
      Your chart<br />is waiting.
    </h2>

    <p
      class="mx-auto mb-12 leading-relaxed"
      style="font-size: var(--text-body-lg); color: #8A8A8A; max-width: 34ch;"
    >
      Download free. Your full natal chart in under 60 seconds.
      No account required to start.
    </p>

    <div class="flex flex-col items-center gap-4">
      <a
        href={APP_STORE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="badge-appstore"
        aria-label="Download AstrologyX on the App Store"
      >
        <img
          src="/img/appstore.png"
          alt="Download on the App Store"
          width="190"
          height="63"
          loading="lazy"
          style="height: 63px; width: auto;"
        />
      </a>
      <span style="font-size: 0.7rem; color: #BEBEBE; letter-spacing: 0.05em;">
        4.9 ★ · iOS · Free
      </span>
    </div>
  </div>
</section>

<!-- Sticky mobile CTA bar -->
<div
  id="mobile-cta"
  class="mobile-cta-bar md:hidden"
  role="complementary"
  aria-label="Download banner"
>
  <p style="font-size: 0.8rem; font-weight: 600; color: #111111; line-height: 1.3;">
    Download AstrologyX<br />
    <span style="font-weight: 400; color: #8A8A8A;">Free on the App Store</span>
  </p>
  <a
    href={APP_STORE_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="badge-appstore flex-shrink-0"
    aria-label="Download on the App Store"
  >
    <img
      src="/img/appstore.png"
      alt="App Store"
      width="100"
      height="33"
      style="height: 33px; width: auto;"
    />
  </a>
</div>

<script>
  const ctaBlock = document.getElementById('cta-block');
  if (ctaBlock) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          ctaBlock.classList.add('visible');
          obs.unobserve(ctaBlock);
        }
      },
      { threshold: 0.15 }
    );
    obs.observe(ctaBlock);
  }

  const mobileCta = document.getElementById('mobile-cta');
  const hero = document.getElementById('hero');
  if (mobileCta && hero) {
    const stickyObs = new IntersectionObserver(
      ([entry]) => {
        mobileCta.classList.toggle('show', !entry.isIntersecting);
      },
      { threshold: 0 }
    );
    stickyObs.observe(hero);
  }
</script>
