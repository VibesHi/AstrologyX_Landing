---
import { APP_STORE_URL } from '../../config';
---
<section
  id="download"
  class="py-36 md:py-48 px-6 md:px-12 text-center bg-white"
  aria-label="Download call to action"
>
  <div class="max-w-5xl mx-auto reveal" id="cta-block">
    <h2
      class="font-black uppercase tracking-tighter leading-none mb-12 md:mb-16 text-black"
      style="font-size: clamp(3rem, 8vw, 6rem);"
    >
      Ascend the<br />grid
    </h2>

    <div class="flex flex-col lg:flex-row items-center justify-center gap-12 lg:gap-16">
      <div class="hidden lg:flex flex-col items-center gap-4">
        <img
          src="/img/app-store-qr.png"
          alt="QR code to open AstrologyX on the App Store"
          width="160"
          height="160"
          loading="lazy"
          class="w-40 h-40"
        />
        <p class="font-mono text-[10px] text-black tracking-widest uppercase">Scan to install</p>
      </div>

      <div class="hidden lg:block h-40 w-px bg-black/10" aria-hidden="true"></div>

      <div class="flex flex-col items-center gap-8">
        <a
          href={APP_STORE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="badge-appstore"
          aria-label="Download AstrologyX on the App Store"
        >
          <img
            src="/img/appstore.png"
            alt="Download on the App Store"
            width="190"
            height="63"
            loading="lazy"
            class="h-16 w-auto"
          />
        </a>
        <p class="max-w-xs text-neutral-600 text-sm font-medium">
          Available for iOS on the App Store.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const ctaBlock = document.getElementById('cta-block');
  if (ctaBlock) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          ctaBlock.classList.add('visible');
          obs.unobserve(ctaBlock);
        }
      },
      { threshold: 0.15 }
    );
    obs.observe(ctaBlock);
  }
</script>
