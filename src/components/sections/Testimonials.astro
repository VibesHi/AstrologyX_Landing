---
const quote =
  "The only astrology app that doesn't feel like noise. It's focused, readable, and specific to my chart.";
---
<section
  id="testimonials"
  class="py-36 md:py-48 px-6 md:px-12 text-center"
  style="background: #0e0e0e;"
  aria-label="User testimonial"
>
  <div class="max-w-4xl mx-auto space-y-12 md:space-y-16 reveal" id="testimonial-block">
    <blockquote
      class="font-serif text-3xl md:text-5xl lg:text-6xl italic text-white leading-tight"
      style="font-family: var(--font-serif);"
    >
      &ldquo;{quote}&rdquo;
    </blockquote>
    <div class="flex flex-col items-center gap-4">
      <div class="w-16 h-px bg-white/20" aria-hidden="true"></div>
      <p class="font-mono text-xs md:text-sm tracking-[0.2em] text-[#919191] uppercase">
        App Store review
      </p>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById('testimonial-block');
  if (el) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          obs.unobserve(el);
        }
      },
      { threshold: 0.15 }
    );
    obs.observe(el);
  }
</script>
