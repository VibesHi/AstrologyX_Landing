<section
  id="testimonials"
  class="py-36 md:py-48 px-6 md:px-12 text-center"
  style="background: #0e0e0e;"
  aria-label="User testimonial"
>
  <div class="max-w-4xl mx-auto space-y-12 md:space-y-16 reveal" id="testimonial-block">
    <blockquote
      class="font-serif text-3xl md:text-5xl lg:text-[60px] italic text-white leading-tight max-w-[56rem] mx-auto"
      style="font-family: var(--font-serif);"
    >
      &ldquo;I check the AstrologyX app every day.&rdquo;
    </blockquote>
    <div class="flex flex-col items-center gap-4">
      <div class="w-16 h-px shrink-0 bg-[#919191]" aria-hidden="true"></div>
      <p
        class="font-mono text-xs md:text-sm tracking-[0.175em] uppercase max-w-xl mx-auto"
        style="color: #c6c6c6;"
      >
        Beta user 0944 — Lead systems architect
      </p>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById('testimonial-block');
  if (el) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          obs.unobserve(el);
        }
      },
      { threshold: 0.15 }
    );
    obs.observe(el);
  }
</script>
