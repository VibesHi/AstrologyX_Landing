---
import { APP_STORE_URL } from '../../config';
---
<section
  id="hero"
  class="relative overflow-hidden"
  style="background: #131313; min-height: calc(100vh - 88px);"
  aria-label="Hero"
>
  <div
    class="relative z-10 flex flex-col items-start justify-center px-6 md:px-12 pt-16 pb-24 md:pt-24 md:pb-32"
    style="min-height: calc(100vh - 88px);"
  >
    <h1
      class="hero-in font-black leading-[0.85] tracking-tighter uppercase text-white mb-8 max-w-[min(100%,20ch)]"
      style="font-size: var(--text-hero-mega);"
    >
      AstrologyX
    </h1>

    <p
      class="hero-in hero-in-delay-1 text-2xl md:text-4xl font-light max-w-2xl mb-12"
      style="color: #c6c6c6; line-height: 1.25;"
    >
      <span class="block">Your birth chart. Precise. Clear.</span>
      <span class="block mt-2">Built for daily use.</span>
    </p>

    <div class="hero-in hero-in-delay-2 flex flex-wrap items-center gap-6">
      <a
        href={APP_STORE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="badge-appstore"
        aria-label="Scan QR code to install AstrologyX on the App Store"
      >
        <img
          src="/img/app-store-qr.png"
          alt="Scan QR code to install AstrologyX on the App Store"
          width="512"
          height="512"
          fetchpriority="high"
          class="h-auto w-[min(100%,200px)] md:w-[220px] max-w-full invert"
        />
      </a>
    </div>

    <div
      class="hero-in hero-in-delay-3 absolute bottom-10 left-1/2 -translate-x-1/2 md:left-12 md:translate-x-0 scroll-chevron"
      aria-hidden="true"
    >
      <svg
        width="20"
        height="12"
        viewBox="0 0 20 12"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        style="opacity: 0.35;"
      >
        <path d="M1 1L10 10L19 1" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
</section>
