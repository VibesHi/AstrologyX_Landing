---
import { APP_STORE_URL, APP_VERSION } from '../../config';
---
<section
  id="hero"
  class="relative overflow-x-hidden"
  style="background: #131313; min-height: calc(100vh - 88px);"
  aria-label="Hero"
>
  <div
    class="relative z-10 flex w-full min-w-0 max-w-full flex-col items-start justify-center px-5 sm:px-6 md:px-12 pt-24 pb-20 sm:pt-32 sm:pb-24 md:pt-40 md:pb-28 lg:pt-[192px] lg:pb-[128px]"
    style="min-height: calc(100vh - 88px);"
  >
    <h1
      class="hero-in w-full min-w-0 max-w-full font-black uppercase text-white text-balance mb-6 sm:mb-8"
      style="font-size: var(--text-hero-mega); line-height: 0.9; letter-spacing: -0.045em;"
    >
      ASTROLOGYX
    </h1>

    <p
      class="hero-in hero-in-delay-1 max-w-[42rem] mb-10 sm:mb-12 text-[clamp(1.125rem,0.95rem+1.1vw,2.25rem)] md:text-4xl font-light leading-snug"
      style="color: #c6c6c6;"
    >
      The Planets&rsquo; Language
    </p>

    <div class="hero-in hero-in-delay-2 flex flex-wrap items-center gap-6">
      <a
        href={APP_STORE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="badge-appstore shrink-0"
        aria-label="Download AstrologyX on the App Store"
      >
        <img
          src="/img/appstore.png"
          alt=""
          width="180"
          height="60"
          fetchpriority="high"
          class="h-14 w-auto max-w-[min(100%,200px)]"
        />
      </a>
      <div
        class="flex min-h-14 items-center gap-4 border-l pl-6"
        style="border-color: rgba(71, 71, 71, 0.3);"
      >
        <p class="font-mono text-xs leading-4" style="color: #c6c6c6;">
          VERSION {APP_VERSION}
        </p>
        <p class="font-mono text-xs leading-4 text-white">READY FOR DOWNLOAD</p>
      </div>
    </div>
  </div>
</section>
