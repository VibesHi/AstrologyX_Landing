---
import { APP_STORE_URL, APP_VERSION } from '../../config';
---
<section
  id="hero"
  class="relative overflow-x-hidden"
  style="background: #131313; min-height: calc(100vh - var(--site-nav-height)); min-height: calc(100dvh - var(--site-nav-height));"
  aria-label="Hero"
>
  <div
    class="relative z-10 flex w-full min-w-0 max-w-full flex-col items-start justify-center pl-[max(1.25rem,env(safe-area-inset-left,0px))] pr-[max(1.25rem,env(safe-area-inset-right,0px))] sm:pl-[max(1.5rem,env(safe-area-inset-left,0px))] sm:pr-[max(1.5rem,env(safe-area-inset-right,0px))] md:pl-[max(3rem,env(safe-area-inset-left,0px))] md:pr-[max(3rem,env(safe-area-inset-right,0px))] pt-24 pb-20 sm:pt-32 sm:pb-24 md:pt-40 md:pb-28 lg:pt-[192px] lg:pb-[128px]"
    style="min-height: calc(100vh - var(--site-nav-height)); min-height: calc(100dvh - var(--site-nav-height));"
  >
    <h1
      class="hero-in w-full min-w-0 max-w-full font-black uppercase text-white text-balance mb-6 sm:mb-8"
      style="font-size: var(--text-hero-mega); line-height: 0.9; letter-spacing: -0.045em;"
    >
      ASTROLOGYX
    </h1>

    <h2
      class="hero-in hero-in-delay-1 max-w-[42rem] mb-10 sm:mb-12 text-[clamp(1.125rem,0.95rem+1.1vw,2.25rem)] md:text-4xl font-light leading-snug"
      style="color: #c6c6c6;"
    >
      The astrology app for personal everyday guidance
    </h2>

    <div class="hero-in hero-in-delay-2 flex w-full min-w-0 flex-col items-stretch sm:flex-row sm:items-center gap-4 sm:gap-6">
      <a
        href={APP_STORE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="badge-appstore inline-flex shrink-0 self-start"
        aria-label="Download AstrologyX on the App Store"
      >
        <img
          src="/appstore.png"
          alt=""
          width="1558"
          height="505"
          fetchpriority="high"
          class="h-14 w-auto max-w-[min(100%,200px)]"
        />
      </a>
    </div>
  </div>
</section>
