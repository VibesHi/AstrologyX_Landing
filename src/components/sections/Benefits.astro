---
const benefits = [
  {
    icon: `<svg width="40" height="40" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M14 2L16.5 9.5L24 12L16.5 14.5L14 22L11.5 14.5L4 12L11.5 9.5L14 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <circle cx="14" cy="12" r="2" fill="currentColor"/>
    </svg>`,
    headline: 'Algorithmic insights',
    body: 'Personalised readings from your chart — not one-size horoscopes for every sign. The app focuses on what matters for your placements and transits.',
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M4 20V8h4v12H4zm8-6V4h4v10h-4zm8 4v-8h4v8h-4z" fill="currentColor" opacity="0.9"/>
    </svg>`,
    headline: 'Real-time transits',
    body: 'Track what is active in your chart over time so daily context stays aligned with your life — not a static snapshot.',
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="10" cy="14" r="5" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="18" cy="14" r="5" stroke="currentColor" stroke-width="1.5"/>
      <path d="M3 22c0-3 2.6-5.5 7-5.5h8c4.4 0 7 2.5 7 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    headline: 'Synced compatibility',
    body: 'Compare charts with partners or colleagues. Synastry and overlays that show how two charts meet — clearly and calmly.',
  },
];
---
<section
  id="benefits"
  class="section-pad border-t border-white/[0.04]"
  style="background: #131313;"
  aria-label="Core benefits"
>
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-12 reveal-stagger"
      id="benefits-grid"
    >
      {benefits.map(({ icon, headline, body }) => (
        <article class="benefit-card benefit-card--inverse flex flex-col gap-6">
          <div class="text-white" set:html={icon} />
          <div>
            <h3
              class="text-2xl font-bold uppercase mb-3 tracking-tight"
              style="color: #ffffff;"
            >
              {headline}
            </h3>
            <p style="font-size: var(--text-body); color: #c6c6c6; line-height: 1.65;">
              {body}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        if (el.classList.contains('reveal-stagger')) {
          el.querySelectorAll(':scope > *').forEach((child, i) => {
            setTimeout(() => child.classList.add('visible'), i * 100);
          });
        }
        observer.unobserve(el);
      });
    },
    { threshold: 0.15 }
  );
  const grid = document.getElementById('benefits-grid');
  if (grid) observer.observe(grid);
</script>
