---
const benefits = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="14" cy="14" r="9" stroke="#111111" stroke-width="1.5"/>
      <circle cx="14" cy="14" r="3" stroke="#111111" stroke-width="1.5"/>
      <line x1="14" y1="2" x2="14" y2="6"  stroke="#111111" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="14" y1="22" x2="14" y2="26" stroke="#111111" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="2"  y1="14" x2="6"  y2="14" stroke="#111111" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="22" y1="14" x2="26" y2="14" stroke="#111111" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    headline: 'Your full chart',
    body: 'Every planet, every house, every aspect — calculated from your exact birth time and location.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="3" y="7" width="22" height="16" rx="2" stroke="#111111" stroke-width="1.5"/>
      <line x1="3" y1="12" x2="25" y2="12" stroke="#111111" stroke-width="1.5"/>
      <line x1="10" y1="3" x2="10" y2="9"  stroke="#111111" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="18" y1="3" x2="18" y2="9"  stroke="#111111" stroke-width="1.5" stroke-linecap="round"/>
      <rect x="8"  y="16" width="3" height="3" rx="0.5" fill="#111111" opacity="0.5"/>
      <rect x="17" y="16" width="3" height="3" rx="0.5" fill="#111111" opacity="0.25"/>
    </svg>`,
    headline: 'One daily reading',
    body: 'One precise, AI-crafted insight per day. Relevant to your chart and attuned to current transits.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="10" cy="12" r="5"  stroke="#111111" stroke-width="1.5"/>
      <circle cx="18" cy="12" r="5"  stroke="#111111" stroke-width="1.5"/>
      <path d="M3 24c0-3.5 3.1-6 7-6h8c3.9 0 7 2.5 7 6" stroke="#111111" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    headline: 'Compare with anyone',
    body: 'Synastry charts show how your planets interact with a partner, friend, or colleague.',
  },
];
---
<section
  id="benefits"
  class="section-pad"
  style="background: #ffffff;"
  aria-label="Core benefits"
>
  <div class="max-w-5xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-14 reveal" id="benefits-header">
      <span class="pill-tag mb-5 inline-flex">What you get</span>
      <h2
        class="font-black leading-tight tracking-tight mt-4"
        style="font-size: var(--text-headline); color: #111111;"
      >
        Made to feel right
      </h2>
    </div>

    <!-- Cards -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal-stagger"
      id="benefits-grid"
    >
      {benefits.map(({ icon, headline, body }) => (
        <article class="benefit-card flex flex-col gap-5">
          <div set:html={icon} />
          <div>
            <h3
              class="font-bold mb-2"
              style="font-size: var(--text-subhead); color: #111111; line-height: 1.25;"
            >
              {headline}
            </h3>
            <p style="font-size: var(--text-body); color: #8A8A8A; line-height: 1.65;">
              {body}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        if (el.classList.contains('reveal')) {
          el.classList.add('visible');
        } else if (el.classList.contains('reveal-stagger')) {
          el.querySelectorAll(':scope > *').forEach((child, i) => {
            setTimeout(() => child.classList.add('visible'), i * 100);
          });
        }
        observer.unobserve(el);
      });
    },
    { threshold: 0.15 }
  );
  ['benefits-header', 'benefits-grid'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
