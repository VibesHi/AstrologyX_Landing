---
const benefits = [
  {
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M20 4l1.8 6.2L28 12l-6.2 1.8L20 20l-1.8-6.2L12 12l6.2-1.8L20 4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M20 24l1.2 4.1L25 30l-4.1 1.2L20 35l-1.2-4.1L15 30l4.1-1.2L20 24z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round" opacity="0.85"/>
    </svg>`,
    headline: 'Daily horoscopes',
    body:
      'Your horoscope is generated using real astrological data — no generic predictions. Everything is tailored specifically to your Birth Chart and current planetary influences.',
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M8 28V12h6v16H8zm9-10V8h6v10h-6zm9 6V16h6v18h-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>`,
    headline: 'Birth chart',
    body:
      'Read a quick summary or open a full explanation with clear, beginner‑friendly astrological insights.',
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="14" cy="20" r="6" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="26" cy="20" r="6" stroke="currentColor" stroke-width="1.5"/>
      <path d="M8 28c0-4 3.2-7 12-7s12 3 12 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M20 8v4M20 28v4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" opacity="0.6"/>
    </svg>`,
    headline: 'Planets transit',
    body:
      'Daily guidance about relationships, finances, communication, energy, emotions, and the key themes shaping your day.',
  },
];
---
<section
  id="benefits"
  class="border-t border-white/[0.04] pt-[129px] pb-[128px]"
  style="background: #131313;"
  aria-label="Core benefits"
>
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-x-16 gap-y-16 md:gap-y-0 reveal-stagger"
      id="benefits-grid"
    >
      {benefits.map(({ icon, headline, body }) => (
        <article class="benefit-card benefit-card--inverse flex flex-col gap-6">
          <div class="text-white" set:html={icon} />
          <div>
            <h3
              class="text-2xl font-bold uppercase mb-3 tracking-tight"
              style="color: #ffffff;"
            >
              {headline}
            </h3>
            <p style="font-size: var(--text-body); color: #c6c6c6; line-height: 1.65;">
              {body}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        if (el.classList.contains('reveal-stagger')) {
          el.querySelectorAll(':scope > *').forEach((child, i) => {
            setTimeout(() => child.classList.add('visible'), i * 100);
          });
        }
        observer.unobserve(el);
      });
    },
    { threshold: 0.15 }
  );
  const grid = document.getElementById('benefits-grid');
  if (grid) observer.observe(grid);
</script>
