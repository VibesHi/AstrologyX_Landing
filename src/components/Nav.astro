---
import { APP_STORE_URL } from '../config';
---
<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-40 flex min-w-0 max-w-full items-center justify-between gap-3 px-5 sm:px-6 md:px-12 py-5 sm:py-6 bg-[#131313]/80 backdrop-blur-xl border-b border-white/10"
>
  <a
    href="/"
    class="min-w-0 shrink text-base font-black tracking-tighter text-white uppercase select-none sm:text-xl"
  >
    AstrologyX
  </a>

  <nav
    class="hidden md:flex gap-6 lg:gap-10 items-center justify-center flex-1 min-w-0"
    aria-label="Section shortcuts"
  >
    <a
      class="text-white font-bold border-b-2 border-white pb-1 text-sm uppercase tracking-wide shrink-0"
      href="#benefits"
    >
      Horoscope
    </a>
    <a
      class="text-[#5E5E5E] hover:text-white transition-colors text-sm uppercase tracking-wide shrink-0"
      href="#app-showcase"
    >
      Transits
    </a>
    <a
      class="text-[#5E5E5E] hover:text-white transition-colors text-sm uppercase tracking-wide shrink-0"
      href="#birth-chart"
    >
      Birth Chart
    </a>
    <a
      class="text-[#5E5E5E] hover:text-white transition-colors text-sm uppercase tracking-wide shrink-0"
      href="#testimonials"
    >
      Void
    </a>
  </nav>

  <a
    href={APP_STORE_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="shrink-0 bg-white text-black px-4 py-2 text-xs font-bold uppercase tracking-wide hover:bg-[#353535] hover:text-white transition-all duration-300 sm:px-6 sm:text-sm"
  >
    Download
  </a>
</header>
<div class="h-[88px] shrink-0" aria-hidden="true"></div>
