---
const APP_STORE_URL = 'https://apps.apple.com/app/id1449148271';
---
<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
  style="background: transparent;"
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-white font-black tracking-tight text-lg leading-none select-none">
      AstrologyX
    </a>
    <a
      href={APP_STORE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs font-semibold tracking-widest uppercase text-white/80 hover:text-white transition-colors duration-200 border border-white/20 hover:border-white/60 px-4 py-2 rounded-full"
    >
      Download
    </a>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  let lastScroll = 0;

  const update = () => {
    const y = window.scrollY;
    if (y > 80) {
      nav?.style.setProperty('background', 'rgba(0,0,0,0.92)');
      nav?.style.setProperty('backdrop-filter', 'blur(12px)');
      nav?.style.setProperty('-webkit-backdrop-filter', 'blur(12px)');
      nav?.style.setProperty('border-bottom', '1px solid rgba(255,255,255,0.06)');
    } else {
      nav?.style.setProperty('background', 'transparent');
      nav?.style.setProperty('backdrop-filter', 'none');
      nav?.style.setProperty('-webkit-backdrop-filter', 'none');
      nav?.style.setProperty('border-bottom', 'none');
    }
    lastScroll = y;
  };

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>
