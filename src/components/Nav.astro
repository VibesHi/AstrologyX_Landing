---
import { APP_STORE_URL } from '../config';
---
<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-40 bg-[#F9F7F4]"
  style="border-bottom: 1px solid #EBEBEB;"
>
  <div class="max-w-5xl mx-auto px-6 h-15 flex items-center justify-between" style="height: 60px;">
    <a
      href="/"
      class="font-black tracking-tight text-base leading-none select-none"
      style="color: #111111;"
    >
      AstrologyX
    </a>
    <a
      href={APP_STORE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs font-semibold tracking-widest uppercase transition-all duration-200"
      style="
        color: #111111;
        border: 1px solid #D8D8D8;
        border-radius: 100px;
        padding: 0.45rem 1.1rem;
      "
      onmouseover="this.style.borderColor='#111111'"
      onmouseout="this.style.borderColor='#D8D8D8'"
    >
      Download
    </a>
  </div>
</header>
<!-- Spacer so content doesn't sit under fixed nav -->
<div style="height: 60px;" aria-hidden="true"></div>
