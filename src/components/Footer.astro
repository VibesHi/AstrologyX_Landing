---
const year = new Date().getFullYear();
---
<footer class="w-full bg-[#0E0E0E] flex flex-col md:flex-row justify-between items-start px-6 md:px-12 py-24 md:py-32 gap-16 border-t border-white/[0.04]">
  <div class="flex flex-col gap-8 max-w-md">
    <div class="text-lg font-black text-white uppercase tracking-tight">AstrologyX</div>
    <p class="text-[#5E5E5E] text-sm leading-relaxed">
      A calm interface for your chart, daily context, and compatibility — built for clarity on iOS.
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-24 w-full md:w-auto">
    <div class="flex flex-col gap-4">
      <span class="text-white text-[0.7rem] font-mono tracking-widest mb-1 uppercase">Legal</span>
      <a href="/privacy-policy" class="text-[#5E5E5E] hover:text-white transition-colors text-xs font-mono">
        Privacy
      </a>
      <a href="/terms-of-use" class="text-[#5E5E5E] hover:text-white transition-colors text-xs font-mono">
        Terms
      </a>
    </div>
    <div class="flex flex-col gap-4">
      <span class="text-white text-[0.7rem] font-mono tracking-widest mb-1 uppercase">System</span>
      <a href="#features" class="text-[#5E5E5E] hover:text-white transition-colors text-xs font-mono">
        Features
      </a>
      <a href="/" class="text-[#5E5E5E] hover:text-white transition-colors text-xs font-mono">
        Home
      </a>
    </div>
    <div class="flex flex-col gap-4">
      <span class="text-white text-[0.7rem] font-mono tracking-widest mb-1 uppercase">Social</span>
      <a
        href="https://instagram.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#5E5E5E] hover:text-white transition-colors text-xs font-mono"
      >
        Instagram
      </a>
      <a
        href="https://x.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#5E5E5E] hover:text-white transition-colors text-xs font-mono"
      >
        X / Twitter
      </a>
    </div>
    <div class="flex flex-col gap-4">
      <span class="text-white text-[0.7rem] font-mono tracking-widest mb-1 uppercase">Contact</span>
      <a href="#download" class="text-[#5E5E5E] hover:text-white transition-colors text-xs font-mono">
        Download
      </a>
    </div>
  </div>

  <div class="w-full pt-16 border-t border-white/[0.04] md:hidden">
    <p class="text-[#5E5E5E] text-xs font-mono">© {year} AstrologyX. All rights reserved.</p>
  </div>
  <div class="hidden md:block self-end">
    <p class="text-[#5E5E5E] text-xs font-mono whitespace-nowrap">© {year} AstrologyX. All rights reserved.</p>
  </div>
</footer>
