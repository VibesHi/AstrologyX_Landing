---
const year = new Date().getFullYear();
---
<footer style="background: #ffffff; border-top: 1px solid #EBEBEB;" class="py-10">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <span class="font-black text-sm tracking-tight" style="color: #111111;">AstrologyX</span>

      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap items-center gap-x-6 gap-y-2" style="font-size: 0.75rem; color: #8A8A8A;">
          <li><a href="/privacy-policy" class="hover:text-black transition-colors" style="color: inherit;">Privacy Policy</a></li>
          <li><a href="/terms-of-use" class="hover:text-black transition-colors" style="color: inherit;">Terms of Use</a></li>
          <li>
            <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-black transition-colors" style="color: inherit;">Instagram</a>
          </li>
          <li>
            <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="hover:text-black transition-colors" style="color: inherit;">TikTok</a>
          </li>
          <li>
            <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X" class="hover:text-black transition-colors" style="color: inherit;">X</a>
          </li>
        </ul>
      </nav>

      <p style="font-size: 0.75rem; color: #BEBEBE;">&copy; {year} Vibes LLC. All rights reserved.</p>
    </div>
  </div>
</footer>
