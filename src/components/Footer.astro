---
const year = new Date().getFullYear();
---
<footer class="bg-white border-t border-gray-200 py-10">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <span class="font-black text-sm tracking-tight text-black">AstrologyX</span>

      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-gray-500">
          <li><a href="/privacy-policy" class="hover:text-black transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-of-use" class="hover:text-black transition-colors">Terms of Use</a></li>
          <li>
            <a
              href="https://instagram.com"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              class="hover:text-black transition-colors"
            >Instagram</a>
          </li>
          <li>
            <a
              href="https://tiktok.com"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
              class="hover:text-black transition-colors"
            >TikTok</a>
          </li>
          <li>
            <a
              href="https://x.com"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="X / Twitter"
              class="hover:text-black transition-colors"
            >X</a>
          </li>
        </ul>
      </nav>

      <p class="text-xs text-gray-400">&copy; {year} Vibes LLC. All rights reserved.</p>
    </div>
  </div>
</footer>
